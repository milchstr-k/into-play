# 入境·GameCraft local agent config
# Do not put real keys in this file.

# Option A: OpenAI official API
# AGENT_MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Option B: Anthropic/OneAPI-compatible gateway
AGENT_MODEL_PROVIDER=anthropic
LLM_BASE_URL=https://your-oneapi-compatible-gateway.example.com
LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=your-local-key
# ONE_API_KEY can also live in your local shell or private .env file

AGENT_PORT=8787
