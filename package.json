    "typecheck": "tsc -b --pretty"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@tsparticles/engine": "^4.2.1",
    "@tsparticles/react": "^4.2.1",
    "@tsparticles/slim": "^4.2.1",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "motion": "^12.42.0",
    "pdf-parse": "^2.4.5",
    "phaser": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.5.3",
