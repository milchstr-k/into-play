{
  "name": "into-play",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "node server/agent-server.mjs",
    "check:question-quality": "node scripts/check-question-quality.mjs",
    "dev": "vite --host 0.0.0.0",
    "dev:full": "npm run agent & npm run dev",
